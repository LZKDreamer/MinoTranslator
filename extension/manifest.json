{
  "manifest_version": 3,
  "name": "Mino Translator",
  "version": "1.0.0",
  "description": "YouTube 字幕翻译 & 页面划词翻译",
  "default_locale": "zh_CN",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "notifications",
    "offscreen",
    "unlimitedStorage",
    "alarms"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://*.youtube.com/*",
    "https://apihub.agnes-ai.com/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["src/shared/constants.js", "src/shared/messaging.js", "src/shared/crypto-utils.js", "src/shared/translate-prompt.js", "src/content/timedtext-interceptor.js", "src/content/youtube-subtitles.js", "src/content/subtitle-renderer.js", "src/content/youtube.js", "src/content/floating-translate.js"],
      "css": ["src/content/styles/subtitle.css", "src/content/styles/floating.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "exclude_matches": ["https://www.youtube.com/*"],
      "js": ["src/shared/messaging.js", "src/shared/translate-prompt.js", "src/content/floating-translate.js"],
      "css": ["src/content/styles/floating.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Mino Translator",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/i18n/*.json", "src/content/styles/*.css", "src/content/timedtext-page-hook.js", "src/offscreen/offscreen.html", "src/offscreen/offscreen.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
